<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:textColor="#888888"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp"
            android:textColor="#FFFFFF"
            android:textSize="56sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAc" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="AC" android:textColor="#A6C8FF" android:textSize="22sp"
                app:backgroundTint="#2B3344" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDel" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="⌫" android:textColor="#A6C8FF" android:textSize="22sp"
                app:backgroundTint="#2B3344" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlusMinus" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="+/-" android:textColor="#A6C8FF" android:textSize="22sp"
                app:backgroundTint="#2B3344" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDiv" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="÷" android:textColor="#A6C8FF" android:textSize="28sp"
                app:backgroundTint="#2B3344" app:cornerRadius="40dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn7" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="7" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn8" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="8" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn9" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="9" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMul" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="×" android:textColor="#A6C8FF" android:textSize="28sp"
                app:backgroundTint="#2B3344" app:cornerRadius="40dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="4" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn5" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="5" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn6" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="6" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSub" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="−" android:textColor="#A6C8FF" android:textSize="28sp"
                app:backgroundTint="#2B3344" app:cornerRadius="40dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="1" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn2" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="2" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn3" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="3" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdd" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="+" android:textColor="#A6C8FF" android:textSize="28sp"
                app:backgroundTint="#2B3344" app:cornerRadius="40dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPercent" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="%" android:textColor="#FFFFFF" android:textSize="24sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn0" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="0" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDot" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="." android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#1E1E1E" app:cornerRadius="40dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEqual" style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_margin="6dp" android:layout_weight="1"
                android:text="=" android:textColor="#FFFFFF" android:textSize="28sp"
                app:backgroundTint="#7DA0FF" app:cornerRadius="40dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
